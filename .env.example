# =========================================================
# Fracdrop — variables de entorno
# Copia este archivo a .env y rellena los valores reales:
#   cp .env.example .env
# NUNCA subas el .env real al repositorio.
# =========================================================

# MYSQL / MariaDB
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_DATABASE=clasificador_correos
MYSQL_USER=correos_user
MYSQL_PASSWORD=CHANGE_ME_mysql_password

# MONGODB
MONGO_USER=mongo_admin
MONGO_PASSWORD=CHANGE_ME_mongo_password
MONGO_DATABASE=clasificador_correos

# REDIS
REDIS_PASSWORD=CHANGE_ME_redis_password

# BACKEND / JWT
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encriptación de credenciales (clave Fernet, 32 bytes base64)
# Genera una con:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_fernet_key_44_chars_base64

# Admin inicial (se crea en el primer arranque si no existe)
ADMIN_EMAIL=admin@fracdrop.app
ADMIN_PASSWORD=CHANGE_ME_on_first_login

# URL pública de la app (para construir los enlaces de invitación)
APP_PUBLIC_URL=https://fracdrop.app

# SMTP para enviar los emails de invitación
SMTP_HOST=smtp.tuservidor.com
SMTP_PORT=587
SMTP_USER=no-reply@fracdrop.app
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_FROM=Fracdrop <no-reply@fracdrop.app>

# Caducidad de la invitación (días)
INVITATION_EXPIRE_DAYS=7

# N8N
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_n8n_password
N8N_DATABASE=n8n_db

# DROPBOX OAuth (app compartida) — para el botón "Conectar con Dropbox"
# App key/secret de una app de Dropbox (Full Dropbox). Redirect URI a registrar:
# {APP_PUBLIC_URL}/dropbox/callback  (ej: http://localhost:15173/dropbox/callback)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# TIMEZONE
TIMEZONE=Europe/Madrid

# =========================================================
# PUERTOS EN EL HOST (mapeo host -> contenedor)
# Cambiados a un rango alto para evitar choques con servicios ya activos.
# Solo afectan al lado del host; dentro de la red Docker los puertos internos
# siguen siendo los estándar (3306, 27017, 6379, 8000, 5173, 5678).
# =========================================================
MARIADB_HOST_PORT=13306
MONGODB_HOST_PORT=27017
REDIS_HOST_PORT=16379
BACKEND_HOST_PORT=18080
FRONTEND_HOST_PORT=15173
N8N_HOST_PORT=15678

# FRONTEND (debe apuntar al puerto del host del backend)
VITE_API_URL=http://localhost:18080
